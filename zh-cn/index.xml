&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="k">const&lt;/span> &lt;span class="n">lod&lt;/span> &lt;span class="o">=&lt;/span> &lt;span class="n">new&lt;/span> &lt;span class="n">LOD&lt;/span>&lt;span class="p">();&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="n">lod&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">addLevel&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="n">mesh1&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="n">distance1&lt;/span>&lt;span class="p">);&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="n">lod&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">addLevel&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="n">mesh2&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="n">distance2&lt;/span>&lt;span class="p">);&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;h3 id="4渲染模糊处理像素比">4.&lt;strong>渲染模糊处理【像素比】&lt;/strong>
